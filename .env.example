# =============================================================================
# Db-Discord — variáveis de ambiente
# Copie para .env: cp .env.example .env
# =============================================================================

# --- Geral ---
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
WEBHOOK_PATH=/webhooks/github
METRICS_ENABLED=false

# --- Discord (obrigatório) ---
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_BACKUP_CATEGORY_NAME=Backups

# --- GitHub ---
# PAT com escopo: repo, contents:write (Settings → Developer settings → Tokens)
GITHUB_PAT=
GITHUB_WEBHOOK_SECRET=
GITHUB_OWNER=
GITHUB_AUTO_DISCOVER=true
GITHUB_INITIAL_SYNC_COMMITS=30
GITHUB_INCLUDE_FORKS=false

# --- Banco ---
DATABASE_URL=file:./data/db.sqlite

# --- Cache / Fila (memory = Termux/celular; redis = VPS) ---
CACHE_MODE=memory
QUEUE_MODE=memory
REDIS_URL=redis://127.0.0.1:6379

# --- Backup ---
BACKUP_TEMP_DIR=./tmp/backups
BACKUP_CACHE_TTL_SECONDS=3600
MAX_ZIP_SIZE_MB=25
GIT_CLONE_DEPTH=1

# --- Segurança / Permissões ---
# IDs Discord separados por vírgula (admins globais — /config, workspace)
ADMIN_USER_IDS=
DEFAULT_LANGUAGE=en-US
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW_MS=60000

# Permissões por servidor também via /config (cargos e IDs extras)

# --- GitHub App (opcional, em vez de PAT) ---
# GITHUB_APP_ID=
# GITHUB_PRIVATE_KEY=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
