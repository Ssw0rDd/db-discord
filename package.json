{
  "name": "db-discord",
  "version": "1.0.0",
  "description": "Professional GitHub backup, versioning and project management platform for Discord",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop db-discord",
    "pm2:restart": "pm2 restart db-discord",
    "pm2:logs": "pm2 logs db-discord"
  },
  "keywords": [
    "discord",
    "github",
    "backup",
    "bot"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^11.1.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "@prisma/client": "^5.22.0",
    "archiver": "^8.0.0",
    "bullmq": "^5.79.2",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "ioredis": "^5.11.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "simple-git": "^3.36.0",
    "tsyringe": "^4.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/node": "^26.1.0",
    "prisma": "^5.22.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
